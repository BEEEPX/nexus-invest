# ============================================================
# Nexus Invest — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── News API ────────────────────────────────────────────────
# Get a free key at https://newsapi.org/register
# Without this key, the app uses built-in mock articles.
NEWS_API_KEY=your_newsapi_org_key_here

# ── (Optional) Google Cloud Translation API ─────────────────
# Uncomment to use Google Translate instead of MyMemory (free).
# GOOGLE_TRANSLATE_KEY=your_google_cloud_key_here

# ── (Optional) DeepL API ────────────────────────────────────
# DEEPL_API_KEY=your_deepl_key_here
